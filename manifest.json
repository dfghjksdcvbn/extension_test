{

  "name": "chrome_extension",
  "version": "1.0",
  "manifest_version": 3,
  "host_permissions": ["*://*/*"],
  "description": "chrome_extension",
  "permissions": [
    "<all_urls>",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "all_frames": true,
      "css": ["css/invisible.css"],
      "run_at": "document_start"
    }
  ]
}
